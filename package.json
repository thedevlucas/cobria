{
  "name": "cobria-backend",
  "version": "1.0.0",
  "description": "COBRIA Backend API",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && copyfiles -u 1 src/static/**/*.json dist/",
    "test": "jest",
    "railway:setup": "node scripts/railway-setup.js",
    "railway:deploy": "./deploy-railway.sh",
    "railway:config": "node scripts/railway-setup.js && echo 'Configuration files created!'",
    "test:server": "node test-server.js",
    "test:diagnostic": "ts-node src/server-diagnostic.ts",
    "start:diagnostic": "ts-node src/server-diagnostic.ts"
  },
  "keywords": [
    "api",
    "backend",
    "cobria"
  ],
  "author": "COBRIA Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "form-data": "^4.0.4",
    "helmet": "^8.1.0",
    "interpolate-json": "^1.0.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mathjs": "^11.12.0",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "ocr-space-api-wrapper": "^2.4.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.4",
    "twilio": "^4.23.0",
    "typeorm": "^0.3.27",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.23",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.20",
    "@types/pg": "^8.10.9",
    "copyfiles": "^2.4.1",
    "jest": "^29.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
